# ── Vigilo environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── API ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string
PORT=5000

# ── Alert recipient ────────────────────────────────────────────────────────────
# The email address where Vigilo sends security alerts.
# This is the only email setting you need to configure.
# Vigilo handles the sending automatically.
OWNER_EMAIL=owner@yourbusiness.com

# ── Dashboard ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
