# ── Vigilo environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env — it is in .gitignore.

# ── API ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string
PORT=5000

# ── Email alerts ───────────────────────────────────────────────────────────────
# OWNER_EMAIL: where Vigilo sends security alerts TO.
# This can be any email address — Gmail, Outlook, Yahoo, or any provider.
OWNER_EMAIL=owner@yourhostel.com

# SMTP settings: the email account Vigilo sends alerts FROM.
# This must be an account you control with SMTP access enabled.
#
# Provider SMTP settings:
#   Gmail   : smtp.gmail.com          port 587
#   Outlook : smtp-mail.outlook.com   port 587
#   Yahoo   : smtp.mail.yahoo.com     port 587
#
# Important: Gmail and Outlook require an App Password, not your
# regular login password.
#   Gmail App Password  : myaccount.google.com → Security → App passwords
#   Outlook App Password: account.microsoft.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@emailprovider.com
SMTP_PASSWORD=your-app-password

# ── Dashboard ──────────────────────────────────────────────────────────────────
# Only change this if the API runs on a different host or port.
VITE_API_URL=http://localhost:5000
